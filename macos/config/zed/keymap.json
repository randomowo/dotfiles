[
  {
    "bindings": {
      "cmd-shift-f1": "collab::Mute",
      "cmd-shift-f2": "collab::Deafen",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-b": "outline_panel::ToggleFocus",
      "cmd-shift-d": "debug_panel::ToggleFocus",
      "cmd-shift-t": "terminal_panel::ToggleFocus",
      "cmd-shift-s": "task::Spawn",
      "ctrl-tab": "tab_switcher::Toggle",
      "cmd-shift-n": "workspace::NewWindow",
      "cmd-shift-o": [
        "projects::OpenRecent",
        {
          "create_new_window": true
        }
      ],
      "cmd-shift-p": "command_palette::Toggle",
      "cmd--": [
        "zed::DecreaseBufferFontSize",
        {
          "persist": false
        }
      ],
      "cmd-+": "zed::IncreaseBufferFontSize",
      "cmd-=": "zed::ResetBufferFontSize",
      "cmd-0": null,
      "cmd-5": null,
      "cmd-6": null,
      "cmd-7": null,
      "cmd-8": null,
      "cmd-9": null,
      "cmd-k": null
    }
  },
  {
    "context": "!RunModal && !GitPicker",
    "bindings": {
      "cmd-1": null,
      "cmd-2": null,
      "cmd-3": null,
      "cmd-4": null
    }
  },
  {
    "context": "RunModal",
    "bindings": {
      "cmd-1": "new_process_modal::ActivateTaskTab",
      "cmd-2": "new_process_modal::ActivateDebugTab",
      "cmd-3": "new_process_modal::ActivateAttachTab",
      "cmd-4": "new_process_modal::ActivateLaunchTab"
    }
  },
  {
    "context": "GitPicker",
    "bindings": {
      "cmd-1": "git_picker::ActivateBranchesTab",
      "cmd-2": "git_picker::ActivateWorktreesTab",
      "cmd-3": "git_picker::ActivateStashTab",
      "cmd-4": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-n": "workspace::NewFile",
      "shift shift": "file_finder::Toggle",
      "cmd-w": "workspace::CloseActiveDock",
      "cmd-r": "buffer_search::DeployReplace"
    }
  },
  {
    "context": "EmptyPane || (Editor && vim_mode != insert && VimControl)",
    "bindings": {
      "space b": "editor::ToggleBreakpoint",
      "space w s": "pane::SplitDown",
      "space w d": "pane::SplitRight",
      "space w o": "pane::CloseOtherItems",
      "space w e": "editor::ToggleFocus",
      "space t n": "pane::ActivateNextItem",
      "space t p": "pane::ActivatePreviousItem",
      "space g w": "git::Worktree",
      "space g h": "git::FileHistory",
      "space g t": "git::ViewStash",
      "space g b": "git::Branch",
      "space g r": "git::Restore",
      "space g shift-s": "git::ToggleStaged",
      "space g s": "git::StageAndNext",
      "space g u": "git::UnstageAndNext",
      "space o": "editor::ToggleSelectedDiffHunks",
      "space n": "editor::SelectNext",
      "space p": "editor::SelectPrevious",
      "space m": "editor::OpenSelectionsInMultibuffer",
      "shift-w": "vim::NextSubwordStart",
      "shift-b": "vim::PreviousSubwordStart"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "shift-r": [
        "action::Sequence",
        [
          "vim::HelixSubstituteNoYank",
          [
            "vim::HelixPaste",
            {
              "before": true
            }
          ]
        ]
      ]
    }
  },
  {
    "context": "vim_mode != insert && (GitPanel > Editor || CommitEditor)",
    "bindings": {
      "space a": "git::Amend",
      "space c": "git::Commit",
      "space p": "git::Push",
      "space shift-p": "git::ForcePush",
      "space f f": "git::Fetch",
      "space l": "git::Pull",
      "space f c": "git_panel::FocusChanges"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "escape": null,
      "ctrl-[": null
    }
  },
  {
    "context": "AgentPanel > Editor && vim_mode != insert && VimControl",
    "bindings": {
      "space s m": "agent::ToggleModelSelector",
      "space s p": "agent::ToggleProfileSelector",
      "space s d": "agent::OpenAgentDiff",
      "space t": "agent::OpenHistory",
      "ctrl-c": "editor::Cancel"
    }
  }
]
