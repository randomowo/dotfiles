[
  {
    "bindings": {
      "cmd-shift-f1": "collab::Mute",
      "cmd-shift-f2": "collab::Deafen",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-b": "outline_panel::ToggleFocus",
      "cmd-shift-d": "debug_panel::ToggleFocus",
      "cmd-shift-t": "terminal_panel::ToggleFocus",
      "cmd-shift-s": "task::Spawn",
      "ctrl-tab": "tab_switcher::Toggle",
      "cmd-shift-n": "workspace::NewWindow",
      "cmd-0": null,
      "cmd-5": null,
      "cmd-6": null,
      "cmd-7": null,
      "cmd-8": null,
      "cmd-9": null,
      "cmd-k": null
    }
  },
  {
    "context": "!RunModal",
    "bindings": {
      "cmd-1": null,
      "cmd-2": null,
      "cmd-3": null,
      "cmd-4": null
    }
  },
  {
    "context": "RunModal",
    "bindings": {
      "cmd-1": "new_process_modal::ActivateTaskTab",
      "cmd-2": "new_process_modal::ActivateDebugTab",
      "cmd-3": "new_process_modal::ActivateAttachTab",
      "cmd-4": "new_process_modal::ActivateLaunchTab"
    }
  },
  {
    "context": "Pane && vim_mode != insert",
    "bindings": {
      "space t n": "pane::ActivateNextItem",
      "space t p": "pane::ActivatePreviousItem",
      "space w o": "pane::CloseOtherItems"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-n": "workspace::NewFile",
      "shift-cmd-p": "command_palette::Toggle",
      "shift shift": "file_finder::Toggle",
      "shift-cmd-o": [
        "projects::OpenRecent",
        {
          "create_new_window": true
        }
      ],
      "cmd-w": "workspace::CloseActiveDock",
      "cmd-r": "buffer_search::DeployReplace",
      "cmd--": [
        "zed::DecreaseBufferFontSize",
        {
          "persist": false
        }
      ],
      "cmd-+": "zed::IncreaseBufferFontSize",
      "cmd-=": "zed::ResetBufferFontSize"
    }
  },
  {
    "context": "Editor && vim_mode != insert && !Picker",
    "bindings": {
      "space b": "editor::ToggleBreakpoint",
      "space w s": "pane::SplitDown",
      "space w d": "pane::SplitRight"
    }
  },
  {
    "context": "!menu && vim_mode != insert",
    "bindings": {
      "space n": "editor::SelectNext",
      "space p": "editor::SelectPrevious"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "escape": null,
      "ctrl-[": null
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "space s m": "agent::ToggleModelSelector",
      "space s p": "agent::ToggleProfileSelector",
      "space s d": "agent::OpenAgentDiff",
      "space t": "agent::OpenHistory"
    }
  },
  {
    "context": "vim_mode == insert || Terminal || Picker",
    "bindings": {
      "space n": null,
      "space p": null,
      "space w o": null,
      "space t n": null,
      "space t p": null,
      "space s m": null,
      "space s p": null,
      "space s d": null,
      "space t": null
    }
  }
]
