{
  "on_last_window_closed": "quit_app",
  "icon_theme": "Zed (Default)",
  "calls": {
    "mute_on_join": true
  },
  "file_types": {
    "env": [
      ".env*"
    ],
    "Dockerfile": [
      "Dockerfile*"
    ]
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "helix_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank"
  },
  "show_edit_predictions": true,
  "ui_font_size": 13,
  "ui_font_family": "Mononoki Nerd Font",
  "buffer_font_size": 13,
  "agent_ui_font_size": 13,
  "buffer_font_family": "Mononoki Nerd Font",
  "buffer_line_height": {
    "custom": 1
  },
  "whitespace_map": {
    "tab": ">"
  },
  "buffer_font_features": {
    "calt": false
  },
  "terminal": {
    "button": true,
    "copy_on_select": false
  },
  "use_system_window_tabs": true,
  "show_whitespaces": "boundary",
  "preferred_line_length": 120,
  "show_wrap_guides": true,
  "soft_wrap": "bounded",
  "remove_trailing_whitespace_on_save": true,
  "base_keymap": "JetBrains",
  "confirm_quit": false,
  "format_on_save": "off",
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "Gruvbox Dark Hard"
  },
  "tabs": {
    "close_position": "left",
    "git_status": true,
    "show_diagnostics": "errors",
    "file_icons": true,
    "activate_on_close": "left_neighbour"
  },
  "autosave": "on_focus_change",
  "ensure_final_newline_on_save": false,
  "restore_on_startup": "empty_tab",
  "diagnostics": {
    "include_warnings": false,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null
    }
  },
  "languages": {
    "Go": {
      "formatter": [
        {
          "external": {
            "command": "gofmt"
          }
        },
        {
          "external": {
            "command": "golines",
            "arguments": [
              "-m",
              "120",
              "--chain-split-dots",
              "--ignore-generated"
            ]
          }
        },
        {
          "external": {
            "command": "gofumpt",
            "arguments": [
              "-extra"
            ]
          }
        }
      ]
    },
    "Shell Script": {
      "formatter": [
        {
          "external": {
            "command": "shfmt",
            "arguments": [
              "-i",
              "2"
            ]
          }
        }
      ]
    },
    "JSON": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "json"
            ]
          }
        }
      ]
    },
    "JSONC": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "json"
            ]
          }
        }
      ]
    },
    "YAML": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "yaml"
            ]
          }
        }
      ]
    }
  },
  "auto_install_extensions": {
    "html": true,
    "toml": true,
    "dockerfile": true,
    "sql": true,
    "make": true,
    "docker-compose": true,
    "pylsp": true,
    "env": true,
    "basher": true,
    "marksman": true,
    "vacuum": true,
    "nginx": true,
    "git-firefly": true,
    "mcp-server-context7": true
  },
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "api_url": "http://127.0.0.1:11434",
      "max_output_tokens": 64,
      "model": "qwen2.5-coder:1.5b"
    },
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": true,
    "disabled_globs": []
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "language_models": {
    "ollama": {
      "api_url": "http://127.0.0.1:11434",
      "available_models": [
        {
          "display_name": "qwen2.5-coder:7b",
          "name": "qwen2.5-coder:7b",
          "max_tokens": 4096,
          "supports_thinking": false,
          "supports_tools": true
        },
        {
          "display_name": "qwen2.5-coder:1.5b",
          "name": "qwen2.5-coder:1.5b",
          "max_tokens": 2048,
          "supports_thinking": false,
          "supports_tools": true
        },
        {
          "display_name": "gpt-oss:20b",
          "name": "gpt-oss:20b",
          "max_tokens": 32768,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:0.8b",
          "name": "qwen3.5:0.8b",
          "max_tokens": 4096,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:4b",
          "name": "qwen3.5:4b",
          "max_tokens": 32768,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:9b",
          "name": "qwen3.5:9b",
          "max_tokens": 32768,
          "supports_thinking": true,
          "supports_tools": true
        }
      ]
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "confirm"
    },
    "favorite_models": [
      {
        "provider": "ollama",
        "model": "gpt-oss:20b",
        "enable_thinking": false
      },
      {
        "provider": "ollama",
        "model": "qwen2.5-coder:7b",
        "enable_thinking": false
      },
      {
        "provider": "ollama",
        "model": "qwen3.5:4b",
        "enable_thinking": true
      },
      {
        "provider": "ollama",
        "model": "qwen3.5:9b",
        "enable_thinking": true
      }
    ],
    "inline_assistant_use_streaming_tools": true,
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b"
    },
    "inline_alternatives": [],
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "mcp-server-sequential-thinking": {
            "tools": {
              "sequentialthinking": true
            }
          },
          "mcp-server-context7": {
            "tools": {
              "resolve-library-id": true,
              "get-library-docs": true
            }
          }
        }
      },
      "ask": {
        "name": "Ask",
        "tools": {
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "mcp-server-sequential-thinking": {
            "tools": {
              "sequentialthinking": true
            }
          },
          "mcp-server-context7": {
            "tools": {
              "query-docs": true,
              "resolve-library-id": true,
              "get-library-docs": true
            }
          }
        }
      }
    },
    "default_profile": "ask",
    "enabled": true,
    "button": true,
    "dock": "right",
    "default_width": 640,
    "default_height": 320,
    "default_view": "thread",
    "default_model": {
      "enable_thinking": true,
      "provider": "ollama",
      "model": "qwen3.5:9b"
    },
    "single_file_review": true
  }
}
