{
  "use_system_prompts": true,
  "use_system_path_prompts": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "calls": {
    "mute_on_join": true
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": false
    }
  },
  "terminal": {
    "button": true,
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "button": true,
    "sort_mode": "directories_first",
    "hide_root": false,
    "diagnostic_badges": true,
    "bold_folder_labels": true,
    "entry_spacing": "comfortable",
    "dock": "left",
    "starts_open": false
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show_tab_bar_buttons": false
  },
  "tabs": {
    "show_diagnostics": "errors",
    "close_position": "left",
    "file_icons": false,
    "git_status": true
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_user_picture": true,
    "show_onboarding_banner": true,
    "show_branch_name": true,
    "show_menus": false,
    "show_branch_icon": true,
    "show_user_menu": true,
    "show_sign_in": true
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true,
    "active_encoding_button": "non_utf8"
  },
  "file_finder": {
    "modal_max_width": "small"
  },
  "use_smartcase_search": true,
  "search": {
    "button": false,
    "center_on_match": true,
    "whole_word": false
  },
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": false
    }
  },
  "semantic_tokens": "combined",
  "colorize_brackets": false,
  "middle_click_paste": true,
  "inlay_hints": {
    "enabled": true
  },
  "completion_detail_alignment": "left",
  "completions": {
    "lsp_insert_mode": "replace",
    "words": "fallback"
  },
  "show_whitespaces": "boundary",
  "whitespace_map": {
    "tab": ">"
  },
  "use_on_type_format": false,
  "format_on_save": "off",
  "autosave": "on_focus_change",
  "indent_guides": {
    "enabled": false,
    "background_coloring": "disabled",
    "coloring": "fixed"
  },
  "allow_rewrap": "anywhere",
  "preferred_line_length": 120,
  "soft_wrap": "bounded",
  "vim": {
    "cursor_shape": {
      "visual": "hollow"
    },
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": false
  },
  "cursor_blink": false,
  "drag_and_drop_selection": {
    "enabled": false
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true,
    "runnables": true
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false
  },
  "minimap": {
    "show": "never"
  },
  "relative_line_numbers": "disabled",
  "auto_signature_help": false,
  "autoscroll_on_clicks": false,
  "sticky_scroll": {
    "enabled": false
  },
  "scroll_beyond_last_line": "one_page",
  "diff_view_style": "unified",
  "which_key": {
    "enabled": true,
    "delay_ms": 10
  },
  "show_wrap_guides": true,
  "current_line_highlight": "all",
  "ui_font_family": "Mononoki Nerd Font",
  "buffer_line_height": {
    "custom": 1
  },
  "buffer_font_family": "Mononoki Nerd Font",
  "restore_on_startup": "launchpad",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "inline_code_actions": false,
  "extend_comment_on_newline": false,
  "close_panel_on_toggle": true,
  "hover_popover_enabled": true,
  "icon_theme": "Zed (Default)",
  "helix_mode": true,
  "base_keymap": "JetBrains",
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "agent_buffer_font_size": 13,
  "agent_ui_font_size": 13,
  "theme": "Gruvbox Dark Hard",
  "theme_overrides": {
    "Gruvbox Dark Hard": {
      "scrollbar.thumb.background": "#4943404a",
      "scrollbar.thumb.border": "#00000000",
      "scrollbar.thumb.hover_background": "#49434090",
      "scrollbar.thumb.active_background": "#49434090",
      "scrollbar.track.border": "#00000000"
    }
  },
  "file_types": {
    "env": [
      ".env*"
    ],
    "Dockerfile": [
      "Dockerfile*"
    ]
  },
  "languages": {
    "Go": {
      "formatter": [
        {
          "external": {
            "command": "gofmt"
          }
        },
        {
          "external": {
            "command": "golines",
            "arguments": [
              "-m",
              "100",
              "--chain-split-dots",
              "--ignore-generated"
            ]
          }
        },
        {
          "external": {
            "command": "gofumpt",
            "arguments": [
              "-extra"
            ]
          }
        }
      ]
    },
    "Shell Script": {
      "formatter": [
        {
          "external": {
            "command": "shfmt",
            "arguments": [
              "-i",
              "2"
            ]
          }
        }
      ]
    },
    "JSON": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "json"
            ]
          }
        }
      ]
    },
    "JSONC": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "json"
            ]
          }
        }
      ]
    },
    "YAML": {
      "formatter": [
        {
          "external": {
            "command": "yq",
            "arguments": [
              "-I",
              "2",
              "-P",
              "-o",
              "yaml"
            ]
          }
        }
      ]
    }
  },
  "auto_install_extensions": {
    "html": true,
    "toml": true,
    "dockerfile": true,
    "sql": true,
    "make": true,
    "docker-compose": true,
    "env": true,
    "basher": true,
    "marksman": true,
    "vacuum": true,
    "git-firefly": true,
    "mcp-server-context7": true
  },
  "language_models": {
    "ollama": {
      "api_url": "http://127.0.0.1:11434",
      "available_models": [
        {
          "display_name": "qwen2.5-coder:7b",
          "name": "qwen2.5-coder:7b",
          "max_tokens": 4096,
          "supports_thinking": false,
          "supports_tools": true
        },
        {
          "display_name": "qwen2.5-coder:1.5b",
          "name": "qwen2.5-coder:1.5b",
          "max_tokens": 2048,
          "supports_thinking": false,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:0.8b",
          "name": "qwen3.5:0.8b",
          "max_tokens": 4096,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:4b",
          "name": "qwen3.5:4b",
          "max_tokens": 32768,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "qwen3.5:9b",
          "name": "qwen3.5:9b",
          "max_tokens": 32768,
          "supports_thinking": true,
          "supports_tools": true
        },
        {
          "display_name": "gemma4:e4b",
          "name": "gemma4:e4b",
          "max_tokens": 65536,
          "supports_thinking": true,
          "supports_tools": true
        }
      ]
    }
  },
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "api_url": "http://127.0.0.1:11434",
      "max_output_tokens": 64,
      "model": "qwen2.5-coder:3b"
    },
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": true,
    "disabled_globs": []
  },
  "agent": {
    "show_turn_stats": true,
    "cancel_generation_on_terminal_stop": true,
    "enable_feedback": false,
    "tool_permissions": {
      "default": "confirm"
    },
    "favorite_models": [
      {
        "provider": "ollama",
        "model": "qwen3.5:9b",
        "enable_thinking": true
      },
      {
        "provider": "ollama",
        "model": "gemma4:e4b",
        "enable_thinking": true
      }
    ],
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "enable_thinking": false
    },
    "commit_message_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "enable_thinking": false
    },
    "single_file_review": false,
    "model_parameters": [],
    "default_profile": "ask",
    "enabled": true,
    "button": true,
    "dock": "right",
    "default_model": {
      "enable_thinking": true,
      "provider": "ollama",
      "model": "gemma4:e4b"
    }
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  }
}
